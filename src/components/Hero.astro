---
// Hero – full viewport section with grayscale minimal design
---

<section
  class="relative flex min-h-screen items-center justify-center overflow-hidden px-6 pt-24 pb-16 bg-white"
>
  <!-- ── Subtle background grid and glow ── -->
  <div class="pointer-events-none absolute inset-0 opacity-[0.02]" aria-hidden="true">
    <div
      class="absolute inset-0"
      style="background-image: radial-gradient(circle, var(--color-primary-900) 1px, transparent 1px); background-size: 32px 32px;"
    >
    </div>
  </div>
  <!-- Monochrome Glow Blob -->
  <div class="pointer-events-none absolute left-1/2 top-1/2 -translate-x-1/2 -translate-y-1/2 w-[600px] h-[600px] bg-primary-100/50 rounded-full blur-3xl opacity-50 animate-pulse-soft"></div>

  <!-- ── Content ── -->
  <div class="relative z-10 mx-auto max-w-4xl text-center">
    <!-- Badge -->
    <div class="animate-slide-down stagger-1 animate-float mb-8 inline-flex items-center gap-2 rounded-full border border-neutral-200 bg-neutral-50/80 backdrop-blur-sm px-4 py-1.5 text-xs font-medium text-neutral-600 shadow-sm">
      <span class="inline-block h-2 w-2 rounded-full bg-primary-600 animate-pulse"></span>
      Professional AI Assistant
    </div>

    <!-- Headline -->
    <h1 class="animate-slide-up stagger-1 text-5xl leading-tight font-bold tracking-tight text-neutral-900 sm:text-6xl lg:text-7xl">
      Build Your Perfect
      <br />
      <span class="gradient-text">Resume with AI</span>
    </h1>

    <!-- Subtitle -->
    <p class="animate-slide-up stagger-2 mx-auto mt-6 max-w-2xl text-base leading-relaxed text-text-muted sm:text-lg">
      Transform your rough experience into polished, ATS-friendly resumes and
      cover letters in seconds.
      <span class="font-medium text-neutral-900 block mt-2">100% Free. Quick and simple.</span>
    </p>

    <!-- CTA Buttons -->
    <div
      class="animate-slide-up stagger-3 mt-10 flex flex-col items-center justify-center gap-4 sm:flex-row"
    >
      <!-- Primary CTA -->
      <a
        href="/app"
        class="group relative inline-flex items-center gap-2 rounded-lg bg-neutral-900 px-7 py-3.5 text-sm font-semibold text-white shadow-[0_4px_14px_0_oklch(0_0_0_/_0.2)] transition-all duration-300 hover:bg-neutral-800 hover:-translate-y-0.5 hover:shadow-[0_6px_20px_0_oklch(0_0_0_/_0.2)] ring-1 ring-neutral-900/10"
      >
        Get Started Free
        <svg
          xmlns="http://www.w3.org/2000/svg"
          class="h-4 w-4 transition-transform duration-300 group-hover:translate-x-1"
          fill="none"
          viewBox="0 0 24 24"
          stroke="currentColor"
          stroke-width="2"
        >
          <path
            stroke-linecap="round"
            stroke-linejoin="round"
            d="M13 7l5 5m0 0l-5 5m5-5H6"></path>
        </svg>
      </a>

      <!-- Ghost CTA -->
      <a
        href="#how-it-works"
        class="group inline-flex items-center gap-2 rounded-lg border border-neutral-300 bg-white px-6 py-3.5 text-sm font-semibold text-neutral-700 shadow-sm transition-all duration-200 hover:bg-neutral-50 hover:border-neutral-400"
      >
        See How It Works
        <svg
          xmlns="http://www.w3.org/2000/svg"
          class="h-4 w-4 transition-transform duration-300 group-hover:translate-y-0.5"
          fill="none"
          viewBox="0 0 24 24"
          stroke="currentColor"
          stroke-width="2"
        >
          <path
            stroke-linecap="round"
            stroke-linejoin="round"
            d="M19 14l-7 7m0 0l-7-7m7 7V3"></path>
        </svg>
      </a>
    </div>

    <!-- Stats Row -->
    <div
      class="animate-slide-up stagger-4 mt-16 flex flex-wrap items-center justify-center gap-8 sm:gap-12"
    >
      <div class="flex items-center gap-2 text-sm text-text-muted">
        <span
          class="flex h-8 w-8 items-center justify-center rounded-lg bg-neutral-100 text-neutral-600"
        >
          <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" />
          </svg>
        </span>
        <span
          ><span class="font-semibold text-neutral-900">10K+</span> Resumes Generated</span
        >
      </div>
      <div
        class="hidden h-4 w-px bg-neutral-200 sm:block"
        aria-hidden="true"
      ></div>
      <div class="flex items-center gap-2 text-sm text-text-muted">
        <span
          class="flex h-8 w-8 items-center justify-center rounded-lg bg-neutral-100 text-neutral-600"
        >
          <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z" />
          </svg>
        </span>
        <span class="font-semibold text-neutral-900">ATS-Optimized</span>
      </div>
      <div
        class="hidden h-4 w-px bg-neutral-200 sm:block"
        aria-hidden="true"
      ></div>
      <div class="flex items-center gap-2 text-sm text-text-muted">
        <span
          class="flex h-8 w-8 items-center justify-center rounded-lg bg-neutral-100 text-neutral-600"
        >
          <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
          </svg>
        </span>
        <span class="font-semibold text-neutral-900">100% Free</span>
      </div>
    </div>
  </div>
</section>
