---
// Features – 2×2 grid of minimalist cards
const features = [
  {
    icon: 'writing',
    title: 'AI-Powered Writing',
    description:
      'Transform rough bullet points into professional STAR-format achievements that impress recruiters.',
  },
  {
    icon: 'ats',
    title: 'ATS-Optimized',
    description:
      'Every resume is crafted to pass Applicant Tracking Systems with flying colors — never get filtered out.',
  },
  {
    icon: 'privacy',
    title: 'Privacy First',
    description:
      'Your data is never stored. Everything is processed on-the-fly and immediately discarded.',
  },
  {
    icon: 'free',
    title: 'Completely Free',
    description:
      'No hidden fees, no sign-up required. Just paste your experience and go. It\'s that simple.',
  },
];
---

<section class="relative px-6 py-24 lg:py-32 bg-neutral-50/30">
  <div class="relative z-10 mx-auto max-w-6xl">
    <!-- Section Header -->
    <div class="mb-16 text-center">
      <span
        class="mb-4 inline-block rounded-full bg-neutral-100 px-3.5 py-1 text-xs font-semibold tracking-wider text-neutral-600 uppercase"
      >
        Features
      </span>
      <h2 class="text-3xl font-bold tracking-tight text-neutral-900 sm:text-4xl lg:text-5xl">
        Why Choose CareerGen?
      </h2>
      <p class="mx-auto mt-4 max-w-xl text-base text-text-muted">
        Everything you need to create a professional resume — powered by
        cutting-edge AI, designed for real results.
      </p>
    </div>

    <!-- Grid -->
    <div class="grid gap-6 sm:grid-cols-2 lg:grid-cols-4">
      {
        features.map((f, i) => (
          <article
            class={`border border-neutral-200 bg-white group relative rounded-xl p-6 transition-all duration-200 hover:-translate-y-0.5 hover:shadow-sm hover:border-neutral-300 animate-slide-up stagger-${i + 1}`}
          >
            {/* Icon */}
            <div class="mb-4 flex h-10 w-10 items-center justify-center rounded-lg bg-neutral-100 text-neutral-600 transition-transform duration-300 group-hover:scale-105">
              {f.icon === 'writing' && (
                <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M15.232 5.232l3.536 3.536m-2.036-5.036a2.5 2.5 0 113.536 3.536L6.5 21.036H3v-3.572L16.732 3.732z" />
                </svg>
              )}
              {f.icon === 'ats' && (
                <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z" />
                </svg>
              )}
              {f.icon === 'privacy' && (
                <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z" />
                </svg>
              )}
              {f.icon === 'free' && (
                <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M7 7h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2zM9 16h6" />
                </svg>
              )}
            </div>

            {/* Text */}
            <h3 class="mb-2 text-base font-semibold text-neutral-900">{f.title}</h3>
            <p class="text-sm leading-relaxed text-text-muted">
              {f.description}
            </p>
          </article>
        ))
      }
    </div>
  </div>
</section>
