---
// HowItWorks – 3 step horizontal flow
const steps = [
  {
    number: 1,
    icon: 'edit',
    title: 'Paste Your Experience',
    description:
      'Enter your raw work experience and the job description you\'re targeting. No formatting needed.',
  },
  {
    number: 2,
    icon: 'ai',
    title: 'AI Generates',
    description:
      'Our AI analyzes and transforms your input into professional, tailored content optimized for ATS.',
  },
  {
    number: 3,
    icon: 'download',
    title: 'Download PDF',
    description:
      'Review, edit if needed, and download your ATS-friendly resume as a clean, professional PDF.',
  },
];
---

<section id="how-it-works" class="relative px-6 py-24 lg:py-32 bg-white">
  <div class="mx-auto max-w-6xl">
    <!-- Section Header -->
    <div class="mb-20 text-center">
      <span
        class="mb-4 inline-block rounded-full bg-neutral-100 px-3.5 py-1 text-xs font-semibold tracking-wider text-neutral-600 uppercase"
      >
        How It Works
      </span>
      <h2 class="text-3xl font-bold tracking-tight text-neutral-900 sm:text-4xl lg:text-5xl">
        Three Simple Steps
      </h2>
      <p class="mx-auto mt-4 max-w-lg text-base text-text-muted">
        From raw experience to polished resume in under a minute.
      </p>
    </div>

    <!-- Steps -->
    <div class="relative grid gap-8 md:grid-cols-3 md:gap-6">
      <!-- Connector line (desktop only) -->
      <div
        class="pointer-events-none absolute top-8 right-[16.7%] left-[16.7%] hidden border-t border-dashed border-neutral-300 md:block"
        aria-hidden="true"
      >
      </div>

      {
        steps.map((step, i) => (
          <div
            class={`animate-slide-up stagger-${i + 1} relative flex flex-col items-center text-center`}
          >
            {/* Numbered circle with icon */}
            <div class="relative z-10 mb-6 flex h-16 w-16 items-center justify-center rounded-full bg-neutral-900 text-white shadow-sm ring-4 ring-white border border-neutral-200">
              {step.icon === 'edit' && (
                <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z" />
                </svg>
              )}
              {step.icon === 'ai' && (
                <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M9.663 17h4.673M12 3v1m6.364 1.636l-.707.707M21 12h-1M4 12H3m3.343-5.657l-.707-.707m2.828 9.9a5 5 0 117.072 0l-.548.547A3.374 3.374 0 0014 18.469V19a2 2 0 11-4 0v-.531c0-.895-.356-1.754-.988-2.386l-.548-.547z" />
                </svg>
              )}
              {step.icon === 'download' && (
                <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-4l-4 4m0 0l-4-4m4 4V4" />
                </svg>
              )}
            </div>

            {/* Step number badge */}
            <div class="absolute top-0 right-1/2 translate-x-8 z-20 flex h-6 w-6 items-center justify-center rounded-full bg-neutral-600 text-[10px] font-bold text-white shadow-sm">
              {step.number}
            </div>

            {/* Card */}
            <div class="border border-neutral-200 bg-white w-full rounded-xl p-6 transition-all duration-200 hover:-translate-y-0.5 hover:shadow-sm">
              <h3 class="mb-2 text-base font-semibold text-neutral-900">{step.title}</h3>
              <p class="text-sm leading-relaxed text-text-muted">
                {step.description}
              </p>
            </div>
          </div>
        ))
      }
    </div>

    <!-- Bottom CTA -->
    <div class="animate-slide-up stagger-4 mt-16 text-center">
      <a
        href="/app"
        class="group relative inline-flex items-center gap-2 rounded-lg bg-neutral-900 px-6 py-3.5 text-sm font-semibold text-white shadow-sm transition-all duration-200 hover:bg-neutral-800"
      >
        Start Building Now
        <svg
          xmlns="http://www.w3.org/2000/svg"
          class="h-4 w-4 transition-transform duration-300 group-hover:translate-x-0.5"
          fill="none"
          viewBox="0 0 24 24"
          stroke="currentColor"
          stroke-width="2"
        >
          <path
            stroke-linecap="round"
            stroke-linejoin="round"
            d="M13 7l5 5m0 0l-5 5m5-5H6"></path>
        </svg>
      </a>
      <!-- <p class="mt-3 text-xs text-text-muted">No sign-up required</p> -->
    </div>
  </div>
</section>
