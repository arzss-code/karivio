---
// Footer – dark background with gradient top border
---

<footer class="relative bg-neutral-50 text-neutral-600 border-t border-neutral-200">
  <div class="mx-auto max-w-6xl px-6 py-16 lg:px-8">
    <div class="grid gap-12 sm:grid-cols-2 lg:grid-cols-4">
      <!-- Brand -->
      <div class="lg:col-span-2">
        <a href="/" class="inline-flex items-center gap-2 text-neutral-900">
          <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 text-neutral-900" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M21 13.255A23.931 23.931 0 0112 15c-3.183 0-6.22-.62-9-1.745M16 6V4a2 2 0 00-2-2h-4a2 2 0 00-2 2v2m4 6h.01M5 20h14a2 2 0 002-2V8a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
          </svg>
          <span class="text-xl font-bold">CareerGen</span>
        </a>
        <p class="mt-4 max-w-sm text-sm leading-relaxed text-neutral-500">
          AI-powered career tools for everyone. Build professional resumes and
          cover letters in seconds — no account needed.
        </p>
      </div>

      <!-- Quick Links -->
      <div>
        <h3 class="mb-4 text-xs font-semibold tracking-wider text-neutral-800 uppercase">
          Quick Links
        </h3>
        <ul class="space-y-3 text-sm">
          <li>
            <a
              href="/"
              class="transition-colors text-neutral-500 hover:text-neutral-900"
            >
              Home
            </a>
          </li>
          <li>
            <a
              href="/app"
              class="transition-colors text-neutral-500 hover:text-neutral-900"
            >
              Create CV
            </a>
          </li>
        </ul>
      </div>

      <!-- About -->
      <div>
        <h3 class="mb-4 text-xs font-semibold tracking-wider text-neutral-800 uppercase">
          About
        </h3>
        <ul class="space-y-3 text-sm text-neutral-500">
          <li class="flex items-center gap-2">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 text-neutral-500" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z" />
            </svg>
            <span>Your data is never stored</span>
          </li>
          <li>
            Built with
            <a
              href="https://astro.build"
              target="_blank"
              rel="noopener noreferrer"
              class="text-neutral-600 hover:text-neutral-900 font-medium transition-colors"
            >
              Astro
            </a> &amp;
            <a
              href="https://ai.google.dev"
              target="_blank"
              rel="noopener noreferrer"
              class="text-neutral-600 hover:text-neutral-900 font-medium transition-colors"
            >
              Gemini AI
            </a>
          </li>
        </ul>
      </div>
    </div>
  </div>

  <!-- Bottom Bar -->
  <div class="border-t border-neutral-200/60">
    <div class="mx-auto flex max-w-6xl flex-col items-center justify-between gap-2 px-6 py-6 text-xs text-neutral-400 sm:flex-row lg:px-8">
      <span>© 2026 CareerGen. All rights reserved.</span>
      <span>Made with code and AI</span>
    </div>
  </div>
</footer>
