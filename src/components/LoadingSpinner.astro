---
// LoadingSpinner – skeleton loader with shimmer effect for AI generation
---

<div id="loading-spinner" class="hidden">
  <div
    class="rounded-xl border border-border bg-surface p-8 shadow-sm"
  >
    <!-- Status message -->
    <div class="mb-8 flex items-center justify-center gap-3">
      <span
        id="loading-sparkle"
        class="text-neutral-600"
        style="animation: sparkle 2s ease-in-out infinite;"
      >
        <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6 text-neutral-600" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M9.813 15.904L9 21l-.813-5.096L3 15l5.096-.813L9 9l.813 5.187L15 15l-5.187.813zM19.071 4.929l-.707 2.122-2.122.707 2.122.707.707 2.122.707-2.122 2.122-.707-2.122-.707-.707-2.122z" />
        </svg>
      </span>
      <p class="text-sm font-medium text-text-muted">
        AI is crafting your content<span class="loading-dots"><span class="dot">.</span><span class="dot">.</span><span class="dot">.</span></span>
      </p>
    </div>

    <!-- Skeleton lines -->
    <div class="space-y-4">
      <!-- Section header skeleton -->
      <div class="h-5 w-2/5 rounded bg-neutral-100 animate-shimmer"></div>

      <!-- Paragraph skeleton lines -->
      <div class="space-y-3 pt-2">
        <div class="h-3.5 w-full rounded animate-shimmer" style="animation-delay: 0.1s;"></div>
        <div class="h-3.5 w-[90%] rounded animate-shimmer" style="animation-delay: 0.2s;"></div>
        <div class="h-3.5 w-[95%] rounded animate-shimmer" style="animation-delay: 0.3s;"></div>
        <div class="h-3.5 w-4/5 rounded animate-shimmer" style="animation-delay: 0.4s;"></div>
        <div class="h-3.5 w-[85%] rounded animate-shimmer" style="animation-delay: 0.5s;"></div>
        <div class="h-3.5 w-3/5 rounded animate-shimmer" style="animation-delay: 0.6s;"></div>
      </div>

      <!-- Second section header skeleton -->
      <div class="h-5 w-1/3 rounded animate-shimmer mt-6" style="animation-delay: 0.7s;"></div>

      <!-- Second paragraph skeleton -->
      <div class="space-y-3 pt-2">
        <div class="h-3.5 w-full rounded animate-shimmer" style="animation-delay: 0.8s;"></div>
        <div class="h-3.5 w-[92%] rounded animate-shimmer" style="animation-delay: 0.9s;"></div>
        <div class="h-3.5 w-[70%] rounded animate-shimmer" style="animation-delay: 1.0s;"></div>
      </div>
    </div>

    <!-- Progress hint -->
    <div class="mt-8 flex items-center justify-center">
      <div class="flex items-center gap-2 rounded-full bg-neutral-100 px-4 py-2 border border-neutral-200/50">
        <svg
          class="h-4 w-4 animate-spin text-neutral-600"
          xmlns="http://www.w3.org/2000/svg"
          fill="none"
          viewBox="0 0 24 24"
        >
          <circle
            class="opacity-25"
            cx="12"
            cy="12"
            r="10"
            stroke="currentColor"
            stroke-width="4"></circle>
          <path
            class="opacity-75"
            fill="currentColor"
            d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4z"></path>
        </svg>
        <span class="text-xs font-medium text-neutral-600">
          Usually takes 5–15 seconds
        </span>
      </div>
    </div>
  </div>
</div>

<style>
  @keyframes sparkle {
    0%, 100% {
      opacity: 1;
      transform: scale(1) rotate(0deg);
    }
    25% {
      transform: scale(1.15) rotate(5deg);
    }
    50% {
      opacity: 0.6;
      transform: scale(0.95) rotate(-5deg);
    }
    75% {
      transform: scale(1.1) rotate(3deg);
    }
  }

  .loading-dots .dot {
    animation: pulse-dot 1.4s ease-in-out infinite;
    display: inline-block;
  }

  .loading-dots .dot:nth-child(2) {
    animation-delay: 0.2s;
  }

  .loading-dots .dot:nth-child(3) {
    animation-delay: 0.4s;
  }

  @keyframes pulse-dot {
    0%, 80%, 100% {
      opacity: 0.2;
    }
    40% {
      opacity: 1;
    }
  }

  .animate-shimmer {
    background: linear-gradient(
      90deg,
      var(--color-surface-alt) 25%,
      var(--color-border) 37%,
      var(--color-surface-alt) 63%
    );
    background-size: 200% 100%;
    animation: shimmer 1.8s ease-in-out infinite;
  }

  @keyframes shimmer {
    0% {
      background-position: -200% 0;
    }
    100% {
      background-position: 200% 0;
    }
  }
</style>
