---
// Navbar – sticky glassmorphism top bar
---

<nav
  id="main-navbar"
  class="fixed top-0 inset-x-0 z-50 bg-white/70 backdrop-blur-md border-b border-border/50 transition-all duration-200"
>
  <div
    class="mx-auto flex max-w-7xl items-center justify-between px-6 py-4 lg:px-8"
  >
    <!-- Logo -->
    <a href="/" class="group flex items-center gap-2 text-neutral-900">
      <svg
        xmlns="http://www.w3.org/2000/svg"
        class="h-6 w-6 text-neutral-900 transition-transform duration-300 group-hover:scale-105"
        fill="none"
        viewBox="0 0 24 24"
        stroke="currentColor"
        stroke-width="2"
      >
        <path
          stroke-linecap="round"
          stroke-linejoin="round"
          d="M21 13.255A23.931 23.931 0 0112 15c-3.183 0-6.22-.62-9-1.745M16 6V4a2 2 0 00-2-2h-4a2 2 0 00-2 2v2m4 6h.01M5 20h14a2 2 0 002-2V8a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"
        />
      </svg>
      <span class="text-lg font-bold tracking-tight text-neutral-900"
        >CareerGen</span
      >
    </a>

    <!-- Desktop Links -->
    <div class="hidden items-center gap-4 md:flex">
      <a
        href="/"
        class="rounded-lg px-3 py-2 text-sm font-medium text-text-muted transition-colors hover:text-neutral-900"
      >
        Home
      </a>
      <a
        href="/app"
        class="group relative inline-flex items-center gap-1.5 rounded-lg bg-neutral-900 hover:bg-neutral-800 px-4 py-2 text-sm font-medium text-white transition-all duration-200"
      >
        <span>Create CV</span>
        <svg
          xmlns="http://www.w3.org/2000/svg"
          class="h-4 w-4 transition-transform duration-300 group-hover:translate-x-0.5"
          fill="none"
          viewBox="0 0 24 24"
          stroke="currentColor"
          stroke-width="2"
        >
          <path
            stroke-linecap="round"
            stroke-linejoin="round"
            d="M13 7l5 5m0 0l-5 5m5-5H6"></path>
        </svg>
      </a>
    </div>

    <!-- Mobile Hamburger -->
    <button
      id="mobile-menu-btn"
      class="relative flex h-10 w-10 items-center justify-center rounded-lg transition-colors hover:bg-neutral-100 md:hidden"
      aria-label="Toggle menu"
      aria-expanded="false"
    >
      <span class="hamburger-line hamburger-line-1"></span>
      <span class="hamburger-line hamburger-line-2"></span>
      <span class="hamburger-line hamburger-line-3"></span>
    </button>
  </div>

  <!-- Mobile Menu Panel -->
  <div
    id="mobile-menu"
    class="hidden border-b border-neutral-200 bg-white/95 backdrop-blur-md md:hidden"
  >
    <div class="flex flex-col gap-1 px-6 py-4">
      <a
        href="/"
        class="rounded-lg px-4 py-3 text-sm font-medium text-text-muted transition-colors hover:bg-neutral-50 hover:text-neutral-900"
      >
        Home
      </a>
      <a
        href="/app"
        class="mt-2 inline-flex items-center justify-center gap-1.5 rounded-lg bg-neutral-900 hover:bg-neutral-800 px-5 py-3 text-sm font-medium text-white transition-all duration-200"
      >
        Create CV
        <svg
          xmlns="http://www.w3.org/2000/svg"
          class="h-4 w-4"
          fill="none"
          viewBox="0 0 24 24"
          stroke="currentColor"
          stroke-width="2"
        >
          <path
            stroke-linecap="round"
            stroke-linejoin="round"
            d="M14 5l7 7m0 0l-7 7m7-7H3"
          />
        </svg>
      </a>
    </div>
  </div>
</nav>

<style>
  /* Hamburger lines */
  .hamburger-line {
    position: absolute;
    height: 2px;
    width: 20px;
    background-color: var(--color-text);
    border-radius: 9999px;
    transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
  }
  .hamburger-line-1 { transform: translateY(-6px); }
  .hamburger-line-2 { /* center */ }
  .hamburger-line-3 { transform: translateY(6px); }

  /* Open state */
  .menu-open .hamburger-line-1 {
    transform: rotate(45deg);
  }
  .menu-open .hamburger-line-2 {
    opacity: 0;
    transform: scaleX(0);
  }
  .menu-open .hamburger-line-3 {
    transform: rotate(-45deg);
  }

  /* Scrolled style */
  .navbar-scrolled {
    background-color: rgba(255, 255, 255, 0.95) !important;
    border-bottom: 1px solid var(--color-border);
    box-shadow: 0 1px 3px oklch(0 0 0 / 0.04);
  }
</style>

<script>
  function initNavbar() {
    const navbar = document.getElementById('main-navbar');
    const btn = document.getElementById('mobile-menu-btn');
    const menu = document.getElementById('mobile-menu');

    if (!navbar || !btn || !menu) return;

    if (navbar.dataset.initialized === 'true') {
      console.log('[Navbar] Already initialized, skipping');
      return;
    }
    navbar.dataset.initialized = 'true';
    console.log('[Navbar] Initializing navbar handlers...');

    // ── Mobile toggle ──
    btn.addEventListener('click', () => {
      const isOpen = menu.classList.toggle('hidden');
      btn.classList.toggle('menu-open');
      btn.setAttribute('aria-expanded', String(!isOpen));
    });

    // ── Scroll-aware background ──
    const onScroll = () => {
      if (window.scrollY > 10) {
        navbar.classList.add('navbar-scrolled');
      } else {
        navbar.classList.remove('navbar-scrolled');
      }
    };
    window.addEventListener('scroll', onScroll, { passive: true });
    onScroll(); // initial check
  }

  // Initialize immediately
  initNavbar();

  // Re-run on client transitions
  document.addEventListener('astro:page-load', initNavbar);
</script>
