---
// Navbar – sticky glassmorphism top bar with Auth
import { getSupabase } from '../lib/supabase';

const supabase = getSupabase(Astro.cookies);
const { data: { session } } = await supabase.auth.getSession();

let userProfile = null;

if (session) {
  // Fetch credits from profiles
  const { data: profile } = await supabase
    .from('profiles')
    .select('credits_balance, full_name, email')
    .eq('id', session.user.id)
    .single();
  
  if (profile) {
    userProfile = profile;
  } else {
    // Fallback if trigger hasn't fired yet
    userProfile = {
      full_name: session.user.user_metadata?.full_name || 'User',
      email: session.user.email,
      credits_balance: 0
    };
  }
}
---

<nav
  id="main-navbar"
  class="fixed top-0 inset-x-0 z-50 transition-all duration-300 bg-white/50 backdrop-blur-xl border-b border-border/40"
>
  <div class="mx-auto flex max-w-7xl items-center justify-between px-6 py-4 lg:px-8">
    <!-- Logo -->
    <a href="/" class="group flex items-center gap-2 text-neutral-900">
      <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6 text-neutral-900 transition-transform duration-300 group-hover:scale-110" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
        <path stroke-linecap="round" stroke-linejoin="round" d="M21 13.255A23.931 23.931 0 0112 15c-3.183 0-6.22-.62-9-1.745M16 6V4a2 2 0 00-2-2h-4a2 2 0 00-2 2v2m4 6h.01M5 20h14a2 2 0 002-2V8a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/>
      </svg>
      <span class="text-lg font-extrabold tracking-tight text-neutral-900">CareerGen</span>
    </a>

    <!-- Desktop Links & Auth -->
    <div class="hidden items-center gap-4 md:flex">
      <a href="/" class="rounded-lg px-3 py-2 text-sm font-medium text-text-muted transition-colors hover:text-neutral-900 hover:bg-neutral-50/80">Home</a>
      <a href="/app" class="rounded-lg px-3 py-2 text-sm font-medium text-text-muted transition-colors hover:text-neutral-900 hover:bg-neutral-50/80">Create CV</a>
      
      <div class="h-5 w-px bg-neutral-200 mx-2"></div>

      {userProfile ? (
        <div class="flex items-center gap-4">
          <!-- Credits Display -->
          <button type="button" onclick="window.dispatchEvent(new Event('open-topup'))" class="flex items-center gap-1.5 rounded-full bg-neutral-100/80 px-3.5 py-1.5 text-sm font-semibold text-neutral-700 hover:bg-neutral-200/80 transition-all shadow-sm border border-neutral-200 hover:-translate-y-px">
            <span>💎</span>
            <span>{userProfile.credits_balance} Credits</span>
            <svg class="h-3.5 w-3.5 ml-1 opacity-70" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="3">
              <path stroke-linecap="round" stroke-linejoin="round" d="M12 4v16m8-8H4" />
            </svg>
          </button>
          
          <!-- Avatar & Logout -->
          <div class="relative group/user">
            <div class="flex h-9 w-9 cursor-pointer items-center justify-center rounded-full bg-neutral-900 text-sm font-bold text-white shadow-[0_2px_8px_0_oklch(0_0_0_/_0.15)] ring-2 ring-white hover:scale-105 transition-transform duration-200">
              {userProfile.full_name ? userProfile.full_name.charAt(0).toUpperCase() : 'U'}
            </div>
            <!-- Dropdown -->
            <div class="absolute right-0 mt-2 w-48 rounded-xl bg-white/90 backdrop-blur-xl p-2 shadow-xl ring-1 ring-black/5 opacity-0 invisible group-hover/user:opacity-100 group-hover/user:visible transition-all duration-200 origin-top-right translate-y-1 group-hover/user:translate-y-0">
              <div class="px-3 py-2 border-b border-neutral-100 mb-1">
                <p class="text-sm font-medium text-neutral-900 truncate">{userProfile.full_name}</p>
                <p class="text-xs text-text-muted truncate">{userProfile.email}</p>
              </div>
              <form action="/api/auth/signout" method="post">
                <button type="submit" class="w-full text-left cursor-pointer rounded-lg px-3 py-2 text-sm font-medium text-error hover:bg-error/5 transition-colors">
                  Sign Out
                </button>
              </form>
            </div>
          </div>
        </div>
      ) : (
        <form action="/api/auth/signin" method="post">
          <button type="submit" class="group relative inline-flex cursor-pointer items-center gap-2 rounded-lg bg-white border border-neutral-200 hover:bg-neutral-50 px-4 py-2 text-sm font-medium text-neutral-700 transition-all duration-200 shadow-sm hover:shadow">
            <svg class="h-4 w-4" viewBox="0 0 24 24" fill="currentColor">
              <path d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92c-.26 1.37-1.04 2.53-2.21 3.31v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.09z" fill="#4285F4"/>
              <path d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z" fill="#34A853"/>
              <path d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.93l2.85-2.22.81-.62z" fill="#FBBC05"/>
              <path d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z" fill="#EA4335"/>
            </svg>
            <span>Login with Google</span>
          </button>
        </form>
      )}
    </div>

    <!-- Mobile Hamburger (omitted for brevity in styling, same class structure) -->
    <button id="mobile-menu-btn" class="relative flex h-10 w-10 items-center justify-center rounded-lg transition-colors hover:bg-neutral-100 md:hidden" aria-label="Toggle menu" aria-expanded="false">
      <span class="hamburger-line hamburger-line-1"></span>
      <span class="hamburger-line hamburger-line-2"></span>
      <span class="hamburger-line hamburger-line-3"></span>
    </button>
  </div>
</nav>

<style>
  .hamburger-line { position: absolute; height: 2px; width: 20px; background-color: var(--color-text); border-radius: 9999px; transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1); }
  .hamburger-line-1 { transform: translateY(-6px); }
  .hamburger-line-3 { transform: translateY(6px); }
  .menu-open .hamburger-line-1 { transform: rotate(45deg); }
  .menu-open .hamburger-line-2 { opacity: 0; transform: scaleX(0); }
  .menu-open .hamburger-line-3 { transform: rotate(-45deg); }
  .navbar-scrolled { background-color: rgba(255, 255, 255, 0.95) !important; border-bottom: 1px solid var(--color-border); box-shadow: 0 1px 3px oklch(0 0 0 / 0.04); }
</style>

<script>
  function initNavbar() {
    const navbar = document.getElementById('main-navbar');
    const btn = document.getElementById('mobile-menu-btn');
    if (!navbar || !btn) return;
    if (navbar.dataset.initialized === 'true') return;
    navbar.dataset.initialized = 'true';

    btn.addEventListener('click', () => {
      btn.classList.toggle('menu-open');
    });

    const onScroll = () => {
      if (window.scrollY > 10) navbar.classList.add('navbar-scrolled');
      else navbar.classList.remove('navbar-scrolled');
    };
    window.addEventListener('scroll', onScroll, { passive: true });
    onScroll();
  }
  initNavbar();
  document.addEventListener('astro:page-load', initNavbar);
</script>
