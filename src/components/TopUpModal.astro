---
// TopUpModal.astro
---

<div id="topup-modal" class="fixed inset-0 z-[100] hidden flex-col items-center justify-center p-4">
  <div class="fixed inset-0 bg-neutral-900/50 backdrop-blur-sm transition-opacity modal-overlay"></div>
  
  <div class="relative w-full max-w-md scale-95 transform rounded-2xl bg-white p-6 shadow-xl transition-all opacity-0 modal-content">
    <div class="flex items-center justify-between mb-5">
      <h3 class="text-lg font-bold text-neutral-900 flex items-center gap-2">
        <span>💎</span> Top Up Credits
      </h3>
      <button class="modal-close rounded-lg p-1.5 text-neutral-500 hover:bg-neutral-100 transition-colors">
        <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" />
        </svg>
      </button>
    </div>

    <div class="space-y-4">
      <div class="rounded-xl border-2 border-primary-100 bg-primary-50 p-4 relative overflow-hidden">
        <div class="absolute -right-4 -top-4 h-16 w-16 rounded-full bg-primary-200/50"></div>
        <div class="relative z-10">
          <div class="text-sm font-semibold text-primary-900 mb-1">Starter Pack</div>
          <div class="flex items-baseline gap-1 mb-2">
            <span class="text-2xl font-bold text-neutral-900">Rp 10.000</span>
          </div>
          <ul class="text-sm text-neutral-700 space-y-1 mb-4">
            <li class="flex items-center gap-2">
              <svg class="h-4 w-4 text-success" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" /></svg>
              Get 10 AI Generations
            </li>
            <li class="flex items-center gap-2">
              <svg class="h-4 w-4 text-success" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" /></svg>
              Unlock ATS Templates
            </li>
          </ul>
          
          <button id="btn-buy-starter" class="w-full rounded-lg bg-primary-900 py-2.5 text-sm font-semibold text-white shadow-sm hover:bg-primary-800 transition-colors flex items-center justify-center gap-2">
            <span class="buy-text">Buy with QRIS / GoPay</span>
            <svg class="buy-loading hidden h-4 w-4 animate-spin text-white" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24">
              <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="3"></circle>
              <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4z"></path>
            </svg>
          </button>
        </div>
      </div>
    </div>
    
    <p class="mt-4 text-center text-xs text-text-faint">
      Secure payment processed by Midtrans
    </p>
  </div>
</div>

<script is:inline src="https://app.sandbox.midtrans.com/snap/snap.js" data-client-key={import.meta.env.PUBLIC_MIDTRANS_CLIENT_KEY}></script>
<script>
  function initTopUpModal() {
    const modal = document.getElementById('topup-modal');
    if (!modal) return;
    
    if (modal.dataset.initialized === 'true') return;
    modal.dataset.initialized = 'true';

    const overlay = modal.querySelector('.modal-overlay');
    const content = modal.querySelector('.modal-content');
    const closeBtns = modal.querySelectorAll('.modal-close');
    const buyBtn = document.getElementById('btn-buy-starter') as HTMLButtonElement;
    
    // Open modal event listener
    window.addEventListener('open-topup', () => {
      modal.classList.remove('hidden');
      modal.classList.add('flex');
      // small delay for transition
      setTimeout(() => {
        content?.classList.remove('opacity-0', 'scale-95');
        content?.classList.add('opacity-100', 'scale-100');
      }, 10);
    });

    const closeModal = () => {
      content?.classList.remove('opacity-100', 'scale-100');
      content?.classList.add('opacity-0', 'scale-95');
      setTimeout(() => {
        modal.classList.add('hidden');
        modal.classList.remove('flex');
      }, 200);
    };

    closeBtns.forEach(btn => btn.addEventListener('click', closeModal));
    overlay?.addEventListener('click', closeModal);

    // Buy action
    buyBtn?.addEventListener('click', async () => {
      const buyText = buyBtn.querySelector('.buy-text');
      const buyLoading = buyBtn.querySelector('.buy-loading');
      
      buyBtn.disabled = true;
      buyText?.classList.add('hidden');
      buyLoading?.classList.remove('hidden');

      try {
        const response = await fetch('/api/payment/create', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ packageId: 'starter' })
        });
        
        const data = await response.json();
        
        if (!response.ok) {
          if (response.status === 401) {
            alert('Please login first to top up credits.');
            window.location.reload();
            return;
          }
          throw new Error(data.error || 'Payment initialization failed');
        }

        const token = data.token;
        
        // Use Midtrans Snap
        // @ts-ignore
        window.snap.pay(token, {
          onSuccess: function(result: any){
            alert("Payment success! Your credits will be updated shortly.");
            closeModal();
            setTimeout(() => window.location.reload(), 2000);
          },
          onPending: function(result: any){
            alert("Waiting for your payment!");
            closeModal();
          },
          onError: function(result: any){
            alert("Payment failed!");
            closeModal();
          },
          onClose: function(){
            // customer closed the popup without finishing the payment
          }
        });

      } catch (err: any) {
        console.error(err);
        alert(err.message || 'Something went wrong');
      } finally {
        buyBtn.disabled = false;
        buyText?.classList.remove('hidden');
        buyLoading?.classList.add('hidden');
      }
    });
  }

  initTopUpModal();
  document.addEventListener('astro:page-load', initTopUpModal);
</script>
